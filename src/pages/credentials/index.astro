---
import BaseLayout from '../../layouts/BaseLayout.astro';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Dr. Tal Lavian",
  "url": "https://telecommnet.com",
  "jobTitle": "Expert Witness in Telecommunications & Networking",
  "description": "PhD Computer Science, 35+ years experience, 120+ patents, 25+ publications",
  "educationalBackground": [
    {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "PhD",
      "name": "PhD in Computer Science",
      "url": "https://www.berkeley.edu",
      "specialization": "Network Communications"
    }
  ],
  "workLocation": {
    "@type": "Place",
    "name": "San Francisco Bay Area, California"
  },
  "affiliations": [
    {
      "@type": "Organization",
      "name": "UC Berkeley",
      "role": "Industry Fellow and Lecturer"
    },
    {
      "@type": "Organization",
      "name": "IEEE",
      "role": "Senior Member"
    }
  ]
};
---

<BaseLayout
  title="Credentials & Qualifications"
  description="Dr. Tal Lavian's complete professional credentials including PhD, patents, publications, and 35+ years of expert experience in telecommunications and networking."
  schema={personSchema}
>
  <style>
    .hero-section {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--accent-color) 100%);
      color: white;
      padding: 4rem 2rem;
      margin: -2rem -20px 3rem -20px;
    }

    .hero-section h1 {
      color: white;
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .hero-section p {
      font-size: 1.1rem;
      color: rgba(255, 255, 255, 0.95);
      max-width: 800px;
      margin: 0 auto;
    }

    .credentials-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
      margin: 2rem 0;
    }

    .credential-card {
      background: white;
      padding: 2rem;
      border-radius: 8px;
      border-left: 4px solid var(--accent-color);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .credential-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 16px rgba(26, 54, 93, 0.15);
    }

    .credential-card h3 {
      margin-top: 0;
      color: var(--primary-color);
      font-size: 1.3rem;
    }

    .credential-card p {
      margin: 1rem 0 0 0;
      color: #4a5568;
      line-height: 1.7;
    }

    .credential-card ul {
      margin: 1rem 0 0 0;
      padding-left: 1.5rem;
      color: #4a5568;
    }

    .credential-card li {
      margin-bottom: 0.5rem;
    }

    .education-section {
      background-color: var(--light-gray);
      padding: 2rem;
      border-radius: 8px;
      margin: 2rem 0;
      border-left: 4px solid var(--accent-color);
    }

    .education-section h3 {
      color: var(--primary-color);
      margin-top: 0;
    }

    .degree-card {
      background: white;
      padding: 1.5rem;
      border-radius: 6px;
      margin-bottom: 1.5rem;
      border-left: 3px solid var(--accent-color);
    }

    .degree-card:last-child {
      margin-bottom: 0;
    }

    .degree-card strong {
      color: var(--primary-color);
      font-size: 1.1rem;
      display: block;
      margin-bottom: 0.5rem;
    }

    .degree-card em {
      color: #4a5568;
      display: block;
      margin-bottom: 0.75rem;
    }

    .memberships-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
      margin: 2rem 0;
    }

    .membership-card {
      padding: 1.5rem;
      background-color: var(--light-gray);
      border-radius: 8px;
      border-top: 3px solid var(--accent-color);
    }

    .membership-card h4 {
      color: var(--primary-color);
      margin-top: 0;
      margin-bottom: 0.75rem;
      font-size: 1.1rem;
    }

    .membership-card p {
      margin: 0;
      color: #4a5568;
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .industry-experience {
      margin: 2rem 0;
    }

    .company-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin: 1.5rem 0;
    }

    .company-card {
      padding: 1.5rem;
      background-color: var(--light-gray);
      border-radius: 6px;
      border-left: 3px solid var(--accent-color);
    }

    .company-card strong {
      color: var(--primary-color);
      display: block;
      margin-bottom: 0.5rem;
    }

    .company-card p {
      margin: 0;
      color: #4a5568;
      font-size: 0.9rem;
    }

    .key-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 1.5rem;
      margin: 2rem 0;
      text-align: center;
    }

    .stat-card {
      padding: 1.5rem;
      background-color: var(--light-gray);
      border-radius: 8px;
    }

    .stat-number {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--accent-color);
      margin-bottom: 0.5rem;
    }

    .stat-label {
      color: var(--primary-color);
      font-size: 0.95rem;
      font-weight: 600;
    }

    .experience-timeline {
      margin: 2rem 0;
    }

    .timeline-item {
      padding: 1.5rem;
      background-color: var(--light-gray);
      border-radius: 8px;
      border-left: 4px solid var(--accent-color);
      margin-bottom: 1.5rem;
    }

    .timeline-item:last-child {
      margin-bottom: 0;
    }

    .timeline-item strong {
      color: var(--primary-color);
      display: block;
      margin-bottom: 0.25rem;
    }

    .timeline-item em {
      color: #4a5568;
      font-style: italic;
      display: block;
      margin-bottom: 0.5rem;
      font-size: 0.95rem;
    }

    .timeline-item p {
      margin: 0;
      color: #4a5568;
    }

    .patent-credentials {
      background-color: var(--light-gray);
      padding: 2rem;
      border-radius: 8px;
      margin: 2rem 0;
    }

    .patent-credentials h3 {
      color: var(--primary-color);
      margin-top: 0;
    }

    .cta-section {
      text-align: center;
      padding: 2rem;
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--accent-color) 100%);
      border-radius: 8px;
      margin: 3rem 0;
      color: white;
    }

    .cta-section h2 {
      color: white;
      margin-top: 0;
    }

    .cta-button {
      display: inline-block;
      background-color: white;
      color: var(--primary-color);
      padding: 1rem 2rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      transition: background-color 0.3s ease, color 0.3s ease;
      margin-top: 1.5rem;
    }

    .cta-button:hover {
      background-color: var(--accent-color);
      color: white;
      text-decoration: none;
    }

    @media (max-width: 768px) {
      .hero-section h1 {
        font-size: 2rem;
      }

      .hero-section p {
        font-size: 1rem;
      }

      .credentials-grid {
        grid-template-columns: 1fr;
      }

      .memberships-grid {
        grid-template-columns: 1fr;
      }

      .company-list {
        grid-template-columns: 1fr;
      }

      .key-stats {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>

  <div class="hero-section">
    <h1>Credentials & Qualifications</h1>
    <p>Dr. Tal Lavian's comprehensive professional credentials and qualifications in telecommunications, network communications, and expert witness services.</p>
  </div>

  <div class="key-stats">
    <div class="stat-card">
      <div class="stat-number">PhD</div>
      <div class="stat-label">Computer Science</div>
    </div>
    <div class="stat-card">
      <div class="stat-number">35+</div>
      <div class="stat-label">Years Experience</div>
    </div>
    <div class="stat-card">
      <div class="stat-number">120+</div>
      <div class="stat-label">Patents</div>
    </div>
    <div class="stat-card">
      <div class="stat-number">25+</div>
      <div class="stat-label">Publications</div>
    </div>
  </div>

  <h2>Education</h2>

  <div class="education-section">
    <h3 style="margin-top: 0;">PhD in Computer Science</h3>
    <div class="degree-card">
      <strong>University of California, Berkeley</strong>
      <em>Specialization: Network Communications</em>
      <p>Doctoral research focused on advanced network architecture, protocols, and telecommunications systems. Over 20 years of continued research and academic involvement at UC Berkeley following doctoral completion.</p>
    </div>
  </div>

  <h2>Current Academic Positions</h2>

  <div class="credentials-grid">
    <div class="credential-card">
      <h3>Industry Fellow</h3>
      <p><strong>UC Berkeley IEOR & SCET Programs</strong></p>
      <p>Senior academic position providing industry perspective on emerging technologies, telecommunications trends, and technology law.</p>
    </div>

    <div class="credential-card">
      <h3>Lecturer</h3>
      <p><strong>UC Berkeley</strong></p>
      <p>Teaching in network communications, telecommunications systems, and technology law. Mentoring graduate and undergraduate students in computer science and engineering programs.</p>
    </div>

    <div class="credential-card">
      <h3>Technical Co-Chair</h3>
      <p><strong>IEEE Interconnects - Stanford University</strong></p>
      <p>Leadership role in technical standards development and promotion of interconnection technologies and standards.</p>
    </div>
  </div>

  <h2>Professional Certifications & Memberships</h2>

  <div class="memberships-grid">
    <div class="membership-card">
      <h4>Senior Member, IEEE</h4>
      <p>Institute of Electrical and Electronics Engineers - Recognition of professional achievement and technical contributions to telecommunications and networking fields.</p>
    </div>

    <div class="membership-card">
      <h4>Active Member, ACM</h4>
      <p>Association for Computing Machinery - Professional member of leading computer science and technology organization.</p>
    </div>

    <div class="membership-card">
      <h4>IEEE-CNSV Committee</h4>
      <p>IEEE Communications, Networks & Services Visibility Committee - Active participation in technical standards development.</p>
    </div>

    <div class="membership-card">
      <h4>Expert Witness Qualified</h4>
      <p>Qualified as expert witness in multiple federal courts, USPTO, ITC, and international tribunals in telecommunications and networking.</p>
    </div>
  </div>

  <h2>Patent Portfolio</h2>

  <div class="patent-credentials">
    <h3 style="margin-top: 0;">120+ Issued and Filed Patents</h3>
    <p>Inventor on numerous patents covering telecommunications, networking, data communications, mobile wireless systems, and related technologies. Patents have been issued by the U.S. Patent Office and international patent authorities, with citations in numerous patent filings and litigation proceedings.</p>

    <p><strong>Patent Areas of Expertise:</strong></p>
    <ul style="margin: 1rem 0; padding-left: 1.5rem;">
      <li>Network architecture and protocols</li>
      <li>Telecommunications systems</li>
      <li>VoIP and real-time communications</li>
      <li>Mobile wireless and cellular systems</li>
      <li>Data communications</li>
      <li>Network management systems</li>
      <li>Network security and encryption</li>
      <li>Internet and TCP/IP related technologies</li>
    </ul>
  </div>

  <h2>Publications & Research</h2>

  <div class="credentials-grid">
    <div class="credential-card">
      <h3>25+ Publications</h3>
      <p>Peer-reviewed scientific publications and research papers in leading telecommunications and computer science journals and conferences including IEEE, ACM, and other technical publications.</p>
    </div>

    <div class="credential-card">
      <h3>Research Leadership</h3>
      <p>Principal Investigator on DARPA/AFRL research projects. Leadership roles in UC Berkeley research labs including RAD Lab, SAHARA, and ICEBERG projects.</p>
    </div>

    <div class="credential-card">
      <h3>Academic Contributions</h3>
      <p>Presentations at international conferences and technical symposia. Contributions to academic journals and technical publications.</p>
    </div>
  </div>

  <h2>Professional Experience</h2>

  <div class="industry-experience">
    <p>Over 35 years of combined industry and academic experience in telecommunications, networking, and technology:</p>

    <div class="experience-timeline">
      <div class="timeline-item">
        <strong>UC Berkeley</strong>
        <em>20+ years - Industry Fellow, Lecturer, Principal Investigator</em>
        <p>Research and teaching in network communications, telecommunications, and technology law. Leadership in academic research initiatives.</p>
      </div>

      <div class="timeline-item">
        <strong>CRadar.Ai</strong>
        <em>Technology Officer Role</em>
        <p>Leadership in artificial intelligence and machine learning applications to telecommunications and network systems.</p>
      </div>

      <div class="timeline-item">
        <strong>Ixia Communications</strong>
        <em>Senior Technical Leadership</em>
        <p>Network testing and measurement systems. Leadership in product development and technical standards.</p>
      </div>

      <div class="timeline-item">
        <strong>Nortel Labs</strong>
        <em>Senior Research Scientist</em>
        <p>Research in telecommunications systems, protocols, and network architecture for advanced communications solutions.</p>
      </div>

      <div class="timeline-item">
        <strong>Bay Architecture Labs</strong>
        <em>Senior Research Engineer</em>
        <p>Network architecture research and design for telecommunications infrastructure.</p>
      </div>

      <div class="timeline-item">
        <strong>Aptel Communications</strong>
        <em>Technical Leadership</em>
        <p>Development of telecommunications systems and protocols for advanced communications.</p>
      </div>

      <div class="timeline-item">
        <strong>Scitex & Shalev</strong>
        <em>Early Career Positions</em>
        <p>Technology development and research in network communications and data systems.</p>
      </div>
    </div>
  </div>

  <h2>Expert Witness Qualifications</h2>

  <div class="credentials-grid">
    <div class="credential-card">
      <h3>Court Qualifications</h3>
      <p>Qualified as expert witness in U.S. District Courts, U.S. Court of Appeals, Canadian Federal Court, and provincial courts in matters involving telecommunications and networking technologies.</p>
    </div>

    <div class="credential-card">
      <h3>Administrative Tribunal Experience</h3>
      <p>Extensive experience in USPTO Patent Trial & Appeal Board (PTAB) proceedings, International Trade Commission (ITC), and patent re-examination proceedings.</p>
    </div>

    <div class="credential-card">
      <h3>Technical Expertise Areas</h3>
      <p>Qualified to testify on network architecture, telecommunications systems, patent infringement, claim construction, prior art, trade secrets, and industry standards.</p>
    </div>
  </div>

  <h2>Standards & Technical Leadership</h2>

  <div class="credentials-grid">
    <div class="credential-card">
      <h3>IEEE Standards</h3>
      <p>Participation in IEEE technical committees and working groups. Technical Co-Chair responsibilities for interconnection and networking standards.</p>
    </div>

    <div class="credential-card">
      <h3>Industry Standards</h3>
      <p>Involvement in development and promotion of telecommunications and networking standards at national and international levels.</p>
    </div>

    <div class="credential-card">
      <h3>Technical Leadership</h3>
      <p>Recognized technical authority in telecommunications, networking protocols, and network architecture principles.</p>
    </div>
  </div>

  <h2>Areas of Technical Expertise</h2>

  <div class="education-section">
    <h3 style="margin-top: 0;">Core Technical Areas</h3>
    <div style="columns: 2; gap: 2rem;">
      <ul style="margin: 0; padding-left: 1.5rem;">
        <li>Network communications architecture</li>
        <li>Telecommunications systems</li>
        <li>TCP/IP and Internet protocols</li>
        <li>Data communications protocols</li>
        <li>Routing and switching</li>
        <li>VoIP and real-time communications</li>
        <li>Mobile wireless systems</li>
        <li>Cellular network technologies</li>
        <li>Network management systems</li>
        <li>Network security and encryption</li>
        <li>Streaming media and content delivery</li>
        <li>Patent infringement analysis</li>
        <li>Claim construction</li>
        <li>Prior art analysis</li>
        <li>Trade secret litigation</li>
        <li>Technology licensing and royalties</li>
      </ul>
    </div>
  </div>

  <div class="cta-section">
    <h2>Need Expert Testimony or Technical Analysis?</h2>
    <p>Contact Dr. Tal Lavian to discuss how his expertise and qualifications can support your litigation or technical needs.</p>
    <a href="/contact/" class="cta-button">Schedule a Consultation</a>
  </div>
</BaseLayout>
