        <p class="policy-footer">
          &copy; {new Date().getFullYear()} TelecommNet Engineering, Inc. All rights reserved.<br />
          See also: <a href="/privacy-policy/">Privacy Policy</a>
        </p>

      </div>
      <Sidebar />
    </div>
  </div>
</BaseLayout>

<style is:global>
  .legal-page {
    max-width: 820px;
    line-height: 1.75;
  }

  .legal-page h2 {
    margin-top: 2rem;
    margin-bottom: 0.6rem;
    font-size: 1.2rem;
    color: #1F4E79;
    border-bottom: 2px solid #D6E4F0;
    padding-bottom: 0.3rem;
  }

  .legal-page p {
    margin-bottom: 1rem;
    font-size: 0.97rem;
    color: #333;
  }

  .legal-page ul {
    margin: 0.5rem 0 1rem 1.5rem;
  }

  .legal-page ul li {
    margin-bottom: 0.4rem;
    font-size: 0.97rem;
    color: #333;
  }

  .legal-page a {
    color: #2E75B6;
    text-decoration: underline;
  }

  .effective-date {
    background: #F2F7FC;
    border-left: 4px solid #2E75B6;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    color: #555;
  }

  .policy-footer {
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid #ddd;
    font-size: 0.88rem;
    color: #777;
  }
</style>
