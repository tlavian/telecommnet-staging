---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { privacySchema, privacyTitle, privacyDescription } from '../../lib/remaining-schemas';

const title = privacyTitle;
const description = privacyDescription;
const lastUpdated = "March 2026";
const effectiveDate = "March 1, 2026";
---

<BaseLayout title={title} description={description} schema={privacySchema} robots="noindex, follow">
  <section class="hero-banner">
    <h1>Privacy Policy</h1>
  </section>

  <div class="container">
    <div class="content-with-sidebar">
      <div class="content-main legal-page">

        <p class="effective-date">
          <strong>Effective Date:</strong> {effectiveDate} &nbsp;|&nbsp;
          <strong>Last Reviewed:</strong> {lastUpdated}
        </p>

        <p>
          This Privacy Policy describes how TelecommNet Engineering, Inc. ("TelecommNet," "we," "us," or "our")
          operates the website located at <strong>telecommnet.com</strong> (the "Site"). We are committed to
          transparency regarding how visitor information is handled.
        </p>

        <h2>1. Information We Collect</h2>
        <p>
          This website <strong>does not collect personal information directly from visitors</strong>.
          We do not operate contact forms, newsletter sign-ups, account registration, or any other
          mechanism by which visitors submit personal information through this Site. We do not use
          advertising networks, retargeting services, or social media tracking pixels.
        </p>
        <p>
          However, we use third-party services (described below) that may automatically process
          certain visitor data in the course of delivering and analyzing website traffic.
        </p>

        <h2>2. Google Analytics</h2>
        <p>
          This Site uses <strong>Google Analytics</strong> (GA4 and Universal Analytics) to understand
          how visitors interact with the Site. Google Analytics collects the following types of
          information automatically:
        </p>
        <ul>
          <li>Pages visited, time spent on pages, and navigation paths</li>
          <li>Approximate geographic location (city/region level, not precise location)</li>
          <li>Device type, browser type, operating system, and screen resolution</li>
          <li>Referring website or search engine</li>
          <li>IP address (anonymized by Google Analytics before storage)</li>
        </ul>
        <p>
          This data is collected by Google using cookies and is processed in accordance with
          <a href="https://policies.google.com/privacy" target="_blank"
          rel="noopener noreferrer" aria-label="Google Privacy Policy (opens in new window)">
          Google's Privacy Policy</a>. We use this information solely to understand website traffic
          patterns and improve Site content. We do not combine Google Analytics data with any
          personally identifiable information. You may opt out of Google Analytics by installing the
          <a href="https://tools.google.com/dlpage/gaoptout" target="_blank"
          rel="noopener noreferrer" aria-label="Google Analytics opt-out browser add-on (opens in new window)">
          Google Analytics Opt-out Browser Add-on</a>.
        </p>

        <h2>3. Cookies</h2>
        <p>
          This Site uses cookies solely in connection with Google Analytics. These cookies are
          first-party cookies set by Google's analytics script (gtag.js) and are used to distinguish
          unique visitors and track session information. We do not use any other cookies &mdash;
          no advertising cookies, no social media cookies, and no third-party tracking cookies.
        </p>

        <h2>4. No Information Sharing or Sale</h2>
        <p>
          We do not sell, rent, trade, or disclose personal information to any third party. Google
          Analytics data is processed by Google under their data processing terms and is not shared
          by us with any other party.
        </p>

        <h2>5. Cloudflare Network Infrastructure</h2>
        <p>
          This Site is delivered through <strong>Cloudflare's global content delivery network (CDN)</strong>.
          As a network-level infrastructure provider, Cloudflare processes internet traffic &mdash; including
          visitor IP addresses &mdash; at the network layer solely to route requests, provide security
          (DDoS protection), and deliver website content. This processing occurs at the infrastructure level
          and is governed by <a href="https://www.cloudflare.com/privacypolicy/" target="_blank"
          rel="noopener noreferrer" aria-label="Cloudflare Privacy Policy (opens in new window)">
          Cloudflare's Privacy Policy</a>.
          TelecommNet does not receive, access, store, or control any visitor data processed by Cloudflare
          at the network layer.
        </p>

        <h2>6. How to Reach Us</h2>
        <p>
          If you have any questions about this Privacy Policy, you may contact us directly:
        </p>
        <ul>
          <li><strong>Name:</strong> Dr. Tal Lavian</li>
          <li><strong>Organization:</strong> TelecommNet Engineering, Inc.</li>
          <li><strong>Location:</strong> Encino, California</li>
          <li><strong>Email:</strong> <a href="mailto:tlavian@telecommnet.com" aria-label="Email Dr. Lavian at tlavian@telecommnet.com">tlavian@telecommnet.com</a></li>
          <li><strong>Phone:</strong> <a href="tel:+14082099112" aria-label="Call Dr. Lavian at +1 (408) 209-9112">+1 (408) 209-9112</a></li>
        </ul>

        <h2>7. Children&rsquo;s Privacy</h2>
        <p>
          This Site is intended for legal professionals and corporate clients seeking expert witness services.
          It is not directed at children under 13. We do not knowingly collect any information from children.
        </p>

        <h2>8. Do Not Track</h2>
        <p>
          Some browsers transmit "Do Not Track" (DNT) signals. This Site uses Google Analytics, which
          does not alter its behavior in response to DNT signals. You may opt out of Google Analytics
          tracking by using the
          <a href="https://tools.google.com/dlpage/gaoptout" target="_blank"
          rel="noopener noreferrer" aria-label="Google Analytics opt-out add-on (opens in new window)">
          Google Analytics Opt-out Browser Add-on</a>.
        </p>

        <h2>9. California Privacy Rights (CCPA/CPRA)</h2>
        <p>
          California residents are entitled to know what personal information is collected, used,
          shared, or sold. This Site collects limited analytics data through Google Analytics
          (as described in Section 2 above). We do not sell personal information. We do not share
          personal information with advertisers or data brokers. California residents may contact us
          at <a href="mailto:tlavian@telecommnet.com">tlavian@telecommnet.com</a> with any
          privacy-related requests. We do not discriminate against any user on any basis.
        </p>

        <h2>10. Changes to This Policy</h2>
        <p>
          We will update this Privacy Policy if our data practices change. The "Effective Date" at the top
          of this page will reflect the date of any revision. We commit to annual review of this policy.
        </p>

        <h2>11. Governing Law</h2>
        <p>
          This Privacy Policy is governed by the laws of the State of California, without regard to
          conflict of law principles.
        </p>

        <nav class="related-resources" aria-label="Related pages">
          <h2>Related Pages</h2>
          <ul class="resource-links">
            <li><a href="/terms-and-conditions/">Terms and Conditions</a></li>
            <li><a href="/contact/">Contact Dr. Lavian</a></li>
            <li><a href="/about-dr-lavian/">About Dr. Tal Lavian</a></li>
          </ul>
        </nav>

        <p class="policy-footer">
          &copy; {new Date().getFullYear()} TelecommNet Engineering, Inc. All rights reserved.<br />
          See also: <a href="/terms-and-conditions/">Terms and Conditions</a>
        </p>

      </div>
      <Sidebar />
    </div>
  </div>
</BaseLayout>

<style is:global>
  .legal-page {
    max-width: 820px;
    line-height: 1.75;
  }

  .legal-page h2 {
    margin-top: 2rem;
    margin-bottom: 0.6rem;
    font-size: 1.2rem;
    color: #1F4E79;
    border-bottom: 2px solid #D6E4F0;
    padding-bottom: 0.3rem;
  }

  .legal-page p {
    margin-bottom: 1rem;
    font-size: 0.97rem;
    color: #333;
  }

  .legal-page ul {
    margin: 0.5rem 0 1rem 1.5rem;
  }

  .legal-page ul li {
    margin-bottom: 0.4rem;
    font-size: 0.97rem;
    color: #333;
  }

  .legal-page a {
    color: #2E75B6;
    text-decoration: underline;
  }

  .effective-date {
    background: #F2F7FC;
    border-left: 4px solid #2E75B6;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    color: #555;
  }

  .policy-footer {
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid #ddd;
    font-size: 0.88rem;
    color: #777;
  }
</style>
