---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": "https://telecommnet.com/expertise/",
      "name": "Expert Witness Services - Technology & Telecommunications",
      "description": "Comprehensive expert witness services across telecommunications, networking, VoIP, wireless, cybersecurity, patent litigation, standards, IoT, cloud computing, and AI/ML by Dr. Tal Lavian, PhD in Computer Science with 35+ years of experience.",
      "provider": {
        "@type": "Person",
        "name": "Dr. Tal Lavian",
        "url": "https://telecommnet.com",
        "telephone": "+1-408-209-9112",
        "email": "tlavian@telecommnet.com"
      },
      "areaServed": {
        "@type": "Country",
        "name": "United States"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Expert Witness Expertise Areas",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Telecommunications Expert Witness Services"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Computer Networking Expert Witness Services"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "VoIP Expert Witness Services"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Wireless & Mobile Expert Witness Services"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Network Security Expert Witness Services"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Patent Litigation Expert Witness Services"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Technology Standards Expert Witness Services"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "IoT & Connected Devices Expert Witness Services"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Cloud Computing Expert Witness Services"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "AI & Machine Learning Expert Witness Services"
            }
          }
        ]
      }
    }
  ]
};
---

<BaseLayout
  title="Areas of Expertise"
  description="Dr. Tal Lavian offers expert witness services across telecommunications, networking, VoIP, wireless, cybersecurity, patent litigation, standards, IoT, cloud computing, and AI/ML. 35+ years experience, 120+ patents, UC Berkeley PhD."
  schema={schema}
>
  <style define:vars={{
    primaryColor: '#1a365d',
    accentColor: '#2b6cb0',
    lightGray: '#f7fafc',
  }}>
    .expertise-hero {
      background: linear-gradient(135deg, var(--primaryColor) 0%, var(--accentColor) 100%);
      color: white;
      padding: 3rem 0;
      margin: -2rem -20px 0 -20px;
      padding-left: 20px;
      padding-right: 20px;
      border-bottom: 4px solid var(--accentColor);
    }

    .expertise-hero h1 {
      color: white;
      font-size: 2.75rem;
      margin-bottom: 1rem;
    }

    .expertise-hero p {
      font-size: 1.1rem;
      margin-bottom: 0;
      max-width: 800px;
      line-height: 1.8;
    }

    .expertise-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin: 3rem 0;
    }

    .expertise-card {
      background: white;
      border: 2px solid #e2e8f0;
      border-radius: 8px;
      padding: 2rem;
      transition: all 0.3s ease;
      box-shadow: 0 2px 8px rgba(26, 54, 93, 0.1);
    }

    .expertise-card:hover {
      border-color: var(--accentColor);
      box-shadow: 0 8px 24px rgba(26, 54, 93, 0.15);
      transform: translateY(-2px);
    }

    .expertise-card h3 {
      margin-top: 0;
      margin-bottom: 1rem;
      color: var(--primaryColor);
      font-size: 1.3rem;
    }

    .expertise-card p {
      margin-bottom: 1.5rem;
      color: #4a5568;
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .expertise-card a {
      display: inline-block;
      background-color: var(--accentColor);
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: 4px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: background-color 0.3s ease;
    }

    .expertise-card a:hover {
      background-color: var(--primaryColor);
      text-decoration: none;
    }

    .expertise-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      display: block;
      color: var(--accentColor);
    }

    .expertise-intro {
      background-color: var(--lightGray);
      padding: 2rem;
      border-left: 4px solid var(--accentColor);
      margin-bottom: 3rem;
      border-radius: 4px;
    }

    .expertise-intro h2 {
      margin-top: 0;
      color: var(--primaryColor);
    }

    .expertise-intro p {
      margin-bottom: 1rem;
    }

    .credentials-summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      margin: 3rem 0;
    }

    .credential-item {
      text-align: center;
      padding: 1.5rem;
      background: var(--lightGray);
      border-radius: 8px;
    }

    .credential-number {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--accentColor);
      display: block;
      margin-bottom: 0.5rem;
    }

    .credential-label {
      color: var(--primaryColor);
      font-weight: 600;
      font-size: 0.95rem;
    }

    @media (max-width: 768px) {
      .expertise-hero h1 {
        font-size: 2rem;
      }

      .expertise-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .credentials-summary {
        grid-template-columns: repeat(2, 1fr);
      }
    }
  </style>

  <div class="expertise-hero">
    <h1>Areas of Expertise</h1>
    <p>Dr. Tal Lavian provides expert witness services across a comprehensive range of technology and telecommunications domains. With a PhD in Computer Science, 35+ years of professional experience, and 120+ patents to his name, Dr. Lavian brings deep technical knowledge and courtroom credibility to complex technology litigation.</p>
  </div>

  <section class="expertise-intro">
    <h2>Why Choose Dr. Tal Lavian as Your Expert Witness?</h2>
    <p>Dr. Lavian combines academic rigor with practical, real-world experience. He has worked at UC Berkeley's prestigious Electrical Engineering and Computer Sciences department for 20 years, conducted groundbreaking research, published over 25 peer-reviewed papers, and built technologies deployed globally. His testimony is grounded in deep technical understanding, industry standards compliance, and objective analysis of complex technical matters.</p>
    <p>Whether your case involves telecommunications infrastructure, network security, patent infringement claims, cloud architecture, or cutting-edge AI systems, Dr. Lavian has the credentials and experience to provide clear, persuasive expert analysis.</p>
  </section>

  <div class="credentials-summary">
    <div class="credential-item">
      <span class="credential-number">35+</span>
      <span class="credential-label">Years Experience</span>
    </div>
    <div class="credential-item">
      <span class="credential-number">120+</span>
      <span class="credential-label">Patents</span>
    </div>
    <div class="credential-item">
      <span class="credential-number">25+</span>
      <span class="credential-label">Publications</span>
    </div>
    <div class="credential-item">
      <span class="credential-number">20</span>
      <span class="credential-label">Years at UC Berkeley</span>
    </div>
  </div>

  <h2 style="text-align: center; margin-top: 3rem; margin-bottom: 2rem;">10 Key Areas of Expertise</h2>

  <div class="expertise-grid">
    <div class="expertise-card">
      <span class="expertise-icon">📞</span>
      <h3>Telecommunications</h3>
      <p>Expert analysis of PSTN architecture, circuit switching, SS7 protocols, SONET transmission systems, TDM technologies, and traditional telecom infrastructure. Covers network architecture, legacy systems, and protocol implementations.</p>
      <a href="/expertise/telecommunications/">Learn More</a>
    </div>

    <div class="expertise-card">
      <span class="expertise-icon">🌐</span>
      <h3>Computer Networking</h3>
      <p>In-depth expertise in LAN, WAN, VPN technologies, MAC layer protocols, Ethernet standards, packet switching, TCP/IP, routing, and network protocol design. Covers LAN switching, network architecture, and protocol compliance.</p>
      <a href="/expertise/networking/">Learn More</a>
    </div>

    <div class="expertise-card">
      <span class="expertise-icon">🔊</span>
      <h3>VoIP</h3>
      <p>Comprehensive knowledge of Voice over IP systems, SIP protocols, RTP media streaming, PSTN integration, VoIP devices, quality of service, and convergence of voice and data networks. Network design and protocol analysis.</p>
      <a href="/expertise/voip/">Learn More</a>
    </div>

    <div class="expertise-card">
      <span class="expertise-icon">📱</span>
      <h3>Wireless & Mobile</h3>
      <p>Expert analysis of Wi-Fi and 802.11 standards, WLAN technologies, mobile device architecture, cellular networks, spectrum management, interference analysis, and mobile computing. RF and wireless protocol expertise.</p>
      <a href="/expertise/wireless/">Learn More</a>
    </div>

    <div class="expertise-card">
      <span class="expertise-icon">🔒</span>
      <h3>Cybersecurity</h3>
      <p>Deep expertise in network security architectures, firewalls, VPN implementations, SSL/TLS encryption, IPSec protocols, tunneling technologies, content filtering, and security gateway design. Security protocol analysis and implementation.</p>
      <a href="/expertise/cybersecurity/">Learn More</a>
    </div>

    <div class="expertise-card">
      <span class="expertise-icon">⚖️</span>
      <h3>Patent Litigation</h3>
      <p>Specialized experience in patent infringement analysis, claim construction, prior art evaluation, and USPTO proceedings including IPR, CBM, and PGR. Testified in US District Court, USPTO, and ITC. 120+ patents.</p>
      <a href="/expertise/patent-litigation/">Learn More</a>
    </div>

    <div class="expertise-card">
      <span class="expertise-icon">📋</span>
      <h3>Technology Standards</h3>
      <p>Authority on IEEE, IETF, and ITU-T standards, RFC specifications, 802.x protocol suite, standards compliance, standards development participation, and standard-based technology implementation and design.</p>
      <a href="/expertise/standards/">Learn More</a>
    </div>

    <div class="expertise-card">
      <span class="expertise-icon">🔌</span>
      <h3>IoT & Connected Devices</h3>
      <p>Expertise in Internet of Things architectures, connected device technologies, sensor networks, IoT protocols, edge computing, M2M communications, and the convergence of traditional networking with IoT systems.</p>
      <a href="/expertise/iot/">Learn More</a>
    </div>

    <div class="expertise-card">
      <span class="expertise-icon">☁️</span>
      <h3>Cloud Computing</h3>
      <p>Deep knowledge of AWS and GCP platforms, cloud architecture, Software-Defined Networking (SDN), virtualization technologies, cloud networking, data center design, and cloud infrastructure deployment. Hands-on experience deploying systems.</p>
      <a href="/expertise/cloud/">Learn More</a>
    </div>

    <div class="expertise-card">
      <span class="expertise-icon">🤖</span>
      <h3>AI & Machine Learning</h3>
      <p>Expertise in machine learning systems, natural language processing, data science and analytics, statistical learning, neural networks, deep learning, and AI implementation across networked and distributed systems.</p>
      <a href="/expertise/ai-ml/">Learn More</a>
    </div>
  </div>

  <section class="expertise-intro" style="margin-top: 3rem;">
    <h2>Expert Witness Process</h2>
    <p><strong>Case Analysis:</strong> Dr. Lavian thoroughly reviews all relevant technical documentation, depositions, and expert reports to develop a comprehensive understanding of the technical issues at stake.</p>
    <p><strong>Technical Analysis:</strong> Using his deep expertise across multiple technology domains, he provides objective analysis of complex technical matters, identifying key technical facts and explaining them clearly.</p>
    <p><strong>Clear Communication:</strong> Expert testimony must be understandable to judges, jurors, and attorneys who may not have technical backgrounds. Dr. Lavian excels at translating complex technology into clear, compelling explanations.</p>
    <p><strong>Credible Opinions:</strong> With 35+ years of experience, academic credentials, published research, and patent portfolio, Dr. Lavian's opinions carry significant weight with courts and opposing counsel.</p>
    <p><strong>Litigation Support:</strong> From initial case assessment through trial, deposition, and settlement discussions, Dr. Lavian provides comprehensive expert support to law firms and their clients.</p>
  </section>

  <section style="text-align: center; margin-top: 3rem; padding: 2rem; background-color: var(--lightGray); border-radius: 8px;">
    <h2 style="margin-top: 0; color: var(--primaryColor);">Ready to Discuss Your Expert Witness Needs?</h2>
    <p style="margin-bottom: 2rem; font-size: 1.05rem;">Contact Dr. Tal Lavian today to discuss how his expertise can support your case.</p>
    <a href="/contact/" style="display: inline-block; background-color: var(--accentColor); color: white; padding: 1rem 2rem; border-radius: 4px; text-decoration: none; font-weight: 600; font-size: 1rem;">Contact Dr. Lavian</a>
  </section>
</BaseLayout>
