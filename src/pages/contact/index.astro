---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { contactSchema, contactTitle, contactDescription } from '../../lib/remaining-schemas';
---

<BaseLayout
  title={contactTitle}
  description={contactDescription}
  schema={contactSchema}
>

  <div class="hero-banner">
    <h1>Contact Dr. Tal Lavian — Telecom Expert Witness</h1>
  </div>

  <div class="container">
    <div class="content-with-sidebar">
      <div class="content-main">

        <h2>Expert Witness Consulting Services</h2>

        <p>Contact Dr. Tal Lavian &ndash; <a href="/">Telecommunications Expert Witness</a>, <a href="/communications-expert-witness/network-communications-expert-witness/">Network Communications</a>, <a href="/communications-expert-witness/internet-expert-witness/">Internet Expert Witness</a>, <a href="/communications-expert-witness/data-communications-expert/">Data Communications</a>, <a href="/communications-expert-witness/mobile-wireless-expert/">mobile wireless</a>, and <a href="/communications-expert-witness/computer-networking-expert-witness/">Computer Networking</a></p>

        <div class="contact-social-icons">
          <a href="https://www.facebook.com/tal.lavianwork" target="_blank" rel="noopener" class="social-icon-link social-facebook" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 320 512" fill="currentColor"><path d="M279.14 288l14.22-92.66h-88.91v-60.13c0-25.35 12.42-50.06 52.24-50.06h40.42V6.26S260.43 0 225.36 0c-73.22 0-121.08 44.38-121.08 124.72v70.62H22.89V288h81.39v224h100.17V288z"/></svg>
          </a>
          <a href="https://x.com/tlavian" target="_blank" rel="noopener" class="social-icon-link social-x" aria-label="X (Twitter)">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 512 512" fill="currentColor"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/tallavian" target="_blank" rel="noopener" class="social-icon-link social-linkedin" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 448 512" fill="currentColor"><path d="M100.28 448H7.4V148.9h92.88zM53.79 108.1C24.09 108.1 0 83.5 0 53.8a53.79 53.79 0 0 1 107.58 0c0 29.7-24.1 54.3-53.79 54.3zM447.9 448h-92.68V302.4c0-34.7-.7-79.2-48.29-79.2-48.29 0-55.69 37.7-55.69 76.7V448h-92.78V148.9h89.08v40.8h1.3c12.4-23.5 42.69-48.3 87.83-48.3 93.96 0 111.32 61.9 111.32 142.3V448z"/></svg>
          </a>
        </div>

        <div class="contact-grid" role="list" aria-label="Contact methods">
          <div class="contact-icon-box" role="listitem">
            <div class="contact-icon">
              <img loading="lazy" src="/images/icons/ui/map-pin.svg" alt="Location icon" width="90" height="90" />
            </div>
            <div class="contact-icon-content">
              <p class="contact-label">Encino, California</p>
            </div>
          </div>

          <div class="contact-icon-box" role="listitem">
            <div class="contact-icon">
              <img loading="lazy" src="/images/icons/ui/phone.svg" alt="Phone icon" width="90" height="90" />
            </div>
            <div class="contact-icon-content">
              <p class="contact-label"><a href="tel:+14082099112" aria-label="Call Dr. Lavian at +1 (408) 209-9112">+1 (408) 209-9112</a></p>
            </div>
          </div>

          <div class="contact-icon-box" role="listitem">
            <div class="contact-icon">
              <img loading="lazy" src="/images/icons/ui/email.svg" alt="Email icon" width="90" height="90" />
            </div>
            <div class="contact-icon-content">
              <p class="contact-label"><a href="mailto:tlavian@telecommnet.com" aria-label="Email Dr. Lavian at tlavian@telecommnet.com">tlavian@telecommnet.com</a></p>
            </div>
          </div>

          <div class="contact-icon-box" role="listitem">
            <div class="contact-icon">
              <img loading="lazy" src="/images/icons/ui/curriculum-vitae.svg" alt="Curriculum Vitae icon" width="60" height="60" />
            </div>
            <div class="contact-icon-content">
              <p class="contact-label"><a href="/Dr-Tal-Lavian-CV-Expert-Witness-Network-Communications-Telecommunications-Internet-Protocols-Mobile-Wireless.pdf" aria-label="Download Dr. Lavian's Curriculum Vitae (PDF)">curriculum vitae</a></p>
            </div>
          </div>
        </div>

        <div class="contact-about">
          <h2>About Dr. Tal Lavian</h2>
          <p>Dr. Tal Lavian is a telecommunications and network communications expert witness with over 35 years of industry experience. He holds a Ph.D. in Computer Science from the University of California, Berkeley, and has been awarded more than 120 U.S. and international patents in telecommunications, networking, and internet protocols.</p>
          <p>Dr. Lavian has provided expert witness testimony in more than 70 cases before federal courts, the Patent Trial and Appeal Board (PTAB), and the International Trade Commission (ITC). His areas of expertise include <a href="/communications-expert-witness/pstn-voip-cellular-expert/">PSTN, VoIP, and cellular systems</a>, <a href="/communications-expert-witness/network-communications-expert-witness/">network communications</a>, <a href="/communications-expert-witness/internet-expert-witness/">internet protocols (TCP/IP)</a>, <a href="/communications-expert-witness/network-security-expert/">network security</a>, <a href="/communications-expert-witness/mobile-wireless-expert/">mobile and wireless technologies</a>, and <a href="/communications-expert-witness/streaming-media-audio-and-video-conferencing-expert/">streaming media</a>.</p>
          <p>He serves corporate legal departments, AmLaw 100 and AmLaw 200 law firms, and intellectual property boutiques nationwide. For a detailed overview of his qualifications, please download his <a href="/Dr-Tal-Lavian-CV-Expert-Witness-Network-Communications-Telecommunications-Internet-Protocols-Mobile-Wireless.pdf">curriculum vitae</a> or visit the <a href="/about-dr-lavian/">About Dr. Lavian</a> page.</p>
        </div>

        <div class="contact-services">
          <h2>Expert Witness Services</h2>
          <p>Dr. Lavian provides comprehensive expert witness services for patent litigation and intellectual property disputes involving telecommunications and network communications technologies. His services include:</p>
          <ul>
            <li><strong>Expert Reports &amp; Declarations</strong> &mdash; Detailed technical analysis for claim construction, infringement, validity, and damages in patent cases involving telecom technologies.</li>
            <li><strong>Deposition Testimony</strong> &mdash; Over 80 depositions completed. Clear, authoritative testimony on complex telecommunications systems including VoIP, routing protocols, and network architectures.</li>
            <li><strong>Trial &amp; Hearing Testimony</strong> &mdash; Experienced testifying before federal judges, juries, PTAB panels, and ITC administrative law judges.</li>
            <li><strong>Technical Consulting</strong> &mdash; Pre-litigation technology assessment, patent portfolio analysis, and prior art research in telecommunications and networking.</li>
            <li><strong>Claim Construction Analysis</strong> &mdash; Interpretation of patent claims involving network protocols, packet processing, switching architectures, and wireless communications standards.</li>
          </ul>

          <h3>Engagement Process</h3>
          <p>To retain Dr. Lavian as an expert witness, contact him directly by phone or email. Initial consultations typically include a review of the technical subject matter, relevant patents, and case timeline. Dr. Lavian works with both plaintiff and defendant parties and has been retained by companies including Apple, Google, Microsoft, Samsung, Cisco, AT&amp;T, and many others.</p>
          <p>Dr. Lavian is based in Encino, California and is available for cases nationwide. He has testified in federal courts across multiple jurisdictions, at the USPTO Patent Trial and Appeal Board (PTAB), and at the International Trade Commission (ITC) in Washington, D.C.</p>
        </div>

      </div>
      <Sidebar />
    </div>
  </div>

</BaseLayout>

<style is:global>
  /* Contact page social icons */
  .contact-social-icons {
    display: flex;
    gap: 20px;
    margin: 20px 0 30px;
    align-items: center;
  }
  .social-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: opacity 0.3s;
  }
  .social-icon-link:hover {
    opacity: 0.7;
  }
  .social-facebook {
    color: #3b5998;
  }
  .social-x {
    color: #000000;
  }
  .social-linkedin {
    color: #0077b5;
  }

  /* Contact page icon-box grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-top: 10px;
  }
  .contact-icon-box {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .contact-icon {
    flex-shrink: 0;
  }
  .contact-icon img {
    display: block;
  }
  .contact-icon-content .contact-label {
    margin: 0;
    font-size: 17px;
    font-weight: 600;
    color: #333;
    border-left: none;
    padding-left: 0;
  }
  .contact-icon-content .contact-label a {
    color: var(--color-blue-accent);
    text-decoration: none;
  }
  .contact-icon-content .contact-label a:hover {
    text-decoration: underline;
  }

  /* Contact page about section */
  .contact-about {
    margin-top: 35px;
    padding-top: 25px;
    border-top: 1px solid #e0e0e0;
  }
  .contact-about h2 {
    font-size: 22px;
    color: #1a1a2e;
    margin-bottom: 15px;
  }
  .contact-about p {
    font-size: 16px;
    line-height: 1.7;
    color: #444;
    margin-bottom: 14px;
  }
  .contact-about a {
    color: var(--color-blue-accent);
    text-decoration: none;
  }
  .contact-about a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
