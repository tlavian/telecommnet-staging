<style is:global>
.corporate-logos {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 20px;
  margin-top: 20px;
  align-items: center;
  justify-items: center;
}
.corporate-logos img {
  max-width: 130px;
  max-height: 60px;
  object-fit: contain;
}
@media (max-width: 992px) {
  .corporate-logos {
    grid-template-columns: repeat(4, 1fr);
  }
}
@media (max-width: 768px) {
  .corporate-logos {
    grid-template-columns: repeat(3, 1fr);
  }
}
</style>

