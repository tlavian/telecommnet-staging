---
interface Props {
  title: string;
  description?: string;
  schema?: object;
  ogImage?: string;
  ogType?: string;
  breadcrumbs?: Array<{name: string; url: string}>;
  robots?: string;
}

const { title, description = "Dr. Tal Lavian — Telecommunications Expert Witness. 80+ cases, 120+ patents. Network communications, VoIP, internet protocols. Ph.D. UC Berkeley.", schema, ogImage, ogType, breadcrumbs, robots = "index, follow" } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = `https://telecommnet.com${currentPath}`;
const defaultOgImage = "/images/og-default.jpg";
// OG images must be absolute URLs for social crawlers
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `https://telecommnet.com${ogImage}`)
  : `https://telecommnet.com${defaultOgImage}`;

// Generate BreadcrumbList schema from breadcrumbs prop
const breadcrumbSchema = breadcrumbs ? {
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((crumb, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": crumb.name,
    "item": `https://telecommnet.com${crumb.url}`
  }))
} : null;

// Merge breadcrumb schema into existing schema @graph, or create standalone
function buildFullSchema(pageSchema: any, bcSchema: any) {
  if (!pageSchema && !bcSchema) return null;
  if (!pageSchema && bcSchema) return { "@context": "https://schema.org", ...bcSchema };
  if (pageSchema && !bcSchema) return pageSchema;
  // If page schema has @graph, add breadcrumb to it
  if (pageSchema["@graph"]) {
    return { ...pageSchema, "@graph": [...pageSchema["@graph"], bcSchema] };
  }
  // Otherwise create @graph with both
  return {
    "@context": "https://schema.org",
    "@graph": [pageSchema["@type"] ? pageSchema : undefined, bcSchema].filter(Boolean)
  };
}

const fullSchema = buildFullSchema(schema, breadcrumbSchema);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <meta name="author" content="Dr. Tal Lavian" />
  <meta name="ahrefs-site-verification" content="a828a830be2be72c8535b41be85d1f3e970eb6d7d52ff5e10761f0fb293c8a78">
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0B1D3A" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="canonical" href={canonicalURL} />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="TelecommNet" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:type" content={ogType || "website"} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Dr. Tal Lavian — Telecommunications Expert Witness" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@tlavian" />
  <meta name="twitter:creator" content="@tlavian" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  {currentPath === '/' && <link rel="preload" as="image" type="image/webp" href="/wp-content/uploads/2022/10/header-banner.webp" fetchpriority="high" />}
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700;900&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700;900&display=swap" rel="stylesheet" /></noscript>
  {fullSchema && <script type="application/ld+json" set:html={JSON.stringify(fullSchema)} />}
  <!-- Google Analytics (deferred for performance — loads after browser idle) -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    (function(){
      function loadGA(){
        var s=document.createElement('script');
        s.src='https://www.googletagmanager.com/gtag/js?id=G-GCHFJ79Q1P';
        s.async=true;
        document.head.appendChild(s);
        gtag('js',new Date());
        gtag('config','G-GCHFJ79Q1P');
      }
      if('requestIdleCallback' in window){requestIdleCallback(loadGA);}
      else{setTimeout(loadGA,2000);}
    })();
  </script>
  <!-- GA4 Event Tracking -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      // Track phone link clicks
      document.querySelectorAll('a[href^="tel:"]').forEach(function(link) {
        link.addEventListener('click', function() {
          gtag('event', 'phone_click', {
            event_category: 'engagement',
            event_label: link.getAttribute('href')
          });
        });
      });
      // Track email link clicks
      document.querySelectorAll('a[href^="mailto:"]').forEach(function(link) {
        link.addEventListener('click', function() {
          gtag('event', 'email_click', {
            event_category: 'engagement',
            event_label: link.getAttribute('href')
          });
        });
      });
      // Track CTA button clicks
      document.querySelectorAll('.cta-button, .hero-cta').forEach(function(btn) {
        btn.addEventListener('click', function() {
          gtag('event', 'cta_click', {
            event_category: 'engagement',
            event_label: btn.textContent.trim()
          });
        });
      });
      // Track contact form submissions
      var contactForm = document.querySelector('form');
      if (contactForm) {
        contactForm.addEventListener('submit', function() {
          gtag('event', 'contact_form_submit', {
            event_category: 'conversion',
            event_label: window.location.pathname
          });
        });
      }
      // Track CV download clicks
      document.querySelectorAll('a[href$=".pdf"]').forEach(function(link) {
        link.addEventListener('click', function() {
          gtag('event', 'file_download', {
            event_category: 'engagement',
            event_label: link.getAttribute('href')
          });
        });
      });
    });
  </script>
  <style is:global>
    /* ── Design Tokens ── */
    :root {
      /* Primary Navy Palette */
      --color-navy: #0B1D3A;
      --color-navy-light: #1a365d;
      --color-navy-medium: #2d4a8a;
      --color-blue: #3a6bc5;
      --color-blue-accent: #4267B2;

      /* Gold Accent */
      --color-gold: #C9A84C;
      --color-gold-hover: #B8952F;
      --color-gold-light: #F5EDD6;

      /* Neutrals */
      --color-text: #2D3748;
      --color-text-light: #718096;
      --color-heading: #0B1D3A;
      --color-link: #1E4D8C;
      --color-border: #E2E8F0;
      --color-bg-light: #F7F8FA;
      --color-bg-section: #EEF3F9;

      /* Typography */
      --font-heading: 'Merriweather', 'Georgia', serif;
      --font-body: 'Inter', 'Roboto', sans-serif;

      /* Spacing */
      --section-padding: 60px;

      /* Shadows */
      --shadow-card: 0 2px 12px rgba(11, 29, 58, 0.08);
      --shadow-card-hover: 0 8px 30px rgba(11, 29, 58, 0.15);

      /* Transitions */
      --transition-fast: 0.2s ease;
      --transition-medium: 0.3s ease;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-body); color: var(--color-text); font-size: 18px; line-height: 1.6; background: #fff; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    a { color: var(--color-link); text-decoration: underline; }
    a:hover { text-decoration: underline; color: var(--color-navy); }
    img { max-width: 100%; height: auto; }

    /* Skip-to-content accessibility link (WCAG 2.2 AA) */
    .skip-to-content {
      position: absolute;
      top: -100%;
      left: 50%;
      transform: translateX(-50%);
      background: var(--color-navy-light);
      color: #fff;
      padding: 12px 24px;
      z-index: 9999;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      border-radius: 0 0 4px 4px;
      transition: top 0.2s;
    }
    .skip-to-content:focus {
      top: 0;
      outline: 3px solid var(--color-blue-accent);
      outline-offset: 2px;
    }

    .top-bar { background: var(--color-navy-light); color: #fff; padding: 8px 0; font-size: 14px; }
    .top-bar .container { display: flex; justify-content: space-between; align-items: center; }
    .top-bar a { color: #fff; text-decoration: none; }
    .top-bar a:hover { opacity: 0.85; text-decoration: none; }
    .top-bar-left { display: flex; align-items: center; gap: 20px; }
    .top-bar-left span { display: flex; align-items: center; gap: 8px; }
    .top-bar-left span svg { flex-shrink: 0; }
    .top-bar-right { display: flex; align-items: center; gap: 10px; }
    .social-icon { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; background: transparent; color: #fff; font-size: 14px; transition: opacity 0.2s; text-decoration: none; }
    .social-icon:hover { opacity: 0.8; text-decoration: none; }

    .main-nav { background: #fff; border-bottom: 1px solid var(--color-border); padding: 14px 0; position: sticky; top: 0; z-index: 100; box-shadow: 0 1px 4px rgba(11, 29, 58, 0.06); }
    .main-nav .container { display: flex; justify-content: space-between; align-items: center; }
    .main-nav a { text-decoration: none; }
    .nav-links { display: flex; list-style: none; gap: 0; align-items: center; }
    .nav-links li { position: relative; }
    .nav-links li a { color: var(--color-text); font-family: var(--font-body); font-size: 15px; font-weight: 500; padding: 8px 16px; display: block; transition: color var(--transition-fast); text-decoration: none; letter-spacing: 0.01em; }
    .nav-links li a:hover, .nav-links li a.active { color: var(--color-blue-accent); text-decoration: none; }
    .nav-links li.has-dropdown:hover .dropdown { display: block; }
    .dropdown { display: none; position: absolute; top: 100%; left: 0; background: #fff; border: 1px solid var(--color-border); box-shadow: 0 8px 24px rgba(11, 29, 58, 0.12); min-width: 280px; z-index: 200; border-radius: 0 0 6px 6px; }
    .dropdown a { display: block; padding: 11px 18px; color: var(--color-text); font-size: 14px; border-bottom: 1px solid #f0f0f0; }
    .dropdown a { text-decoration: none; }
    .dropdown a:hover { background: var(--color-bg-light); color: var(--color-blue-accent); text-decoration: none; }
    .logo-link { display: flex; align-items: center; text-decoration: none; }
    .logo-link:hover { text-decoration: none; }
    .logo-text { font-family: var(--font-heading); font-size: 26px; font-weight: 700; color: var(--color-navy); letter-spacing: -0.5px; }
    .logo-text .accent { color: var(--color-gold); }
    .mobile-toggle { display: none; background: none; border: none; font-size: 24px; cursor: pointer; color: var(--color-text); padding: 4px; }

    .hero-banner { background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-medium) 50%, var(--color-blue) 100%); color: #fff; padding: 70px 0; text-align: center; position: relative; overflow: hidden; }
    .hero-banner::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
    .hero-banner h1 { font-family: var(--font-heading); font-size: 2.4rem; font-weight: 700; position: relative; z-index: 1; max-width: 850px; margin: 0 auto; color: #fff; letter-spacing: -0.02em; line-height: 1.3; }

    /* Hero with background image (homepage) */
    .hero-banner-img { position: relative; background: url('/wp-content/uploads/2022/10/header-banner.webp') center center / cover no-repeat, linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-light) 100%); min-height: 280px; display: flex; align-items: center; justify-content: center; }
    .hero-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(135deg, rgba(11, 29, 58, 0.85) 0%, rgba(26, 54, 93, 0.7) 100%); }
    .hero-content { position: relative; z-index: 1; text-align: center; padding: 70px 20px; width: 100%; }
    .hero-content h1 { font-family: var(--font-heading); font-size: 2.5rem; font-weight: 700; color: #fff; max-width: 850px; margin: 0 auto; letter-spacing: -0.02em; line-height: 1.3; }

    /* Hero credential stats */
    .hero-stats { display: flex; justify-content: center; gap: 50px; margin-top: 30px; position: relative; z-index: 1; }
    .hero-stat { text-align: center; }
    .hero-stat-number { font-family: var(--font-heading); font-size: 2.4rem; font-weight: 900; color: var(--color-gold); line-height: 1; }
    .hero-stat-label { font-size: 0.85rem; color: rgba(255,255,255,0.85); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; }

    /* CTA buttons */
    .cta-button { display: inline-block; padding: 14px 32px; background: var(--color-gold); color: var(--color-navy); font-family: var(--font-body); font-size: 16px; font-weight: 600; text-decoration: none; border-radius: 4px; transition: all var(--transition-medium); border: 2px solid var(--color-gold); letter-spacing: 0.02em; cursor: pointer; }
    .cta-button:hover { background: var(--color-gold-hover); border-color: var(--color-gold-hover); color: #fff; text-decoration: none; transform: translateY(-1px); box-shadow: 0 4px 15px rgba(201, 168, 76, 0.35); }
    .hero-cta { margin-top: 28px; position: relative; z-index: 1; display: inline-block; padding: 16px 38px; font-size: 17px; }
    .cta-button-outline { display: inline-block; padding: 14px 32px; background: transparent; color: #fff; font-family: var(--font-body); font-size: 16px; font-weight: 600; text-decoration: none; border-radius: 4px; transition: all var(--transition-medium); border: 2px solid rgba(255,255,255,0.6); letter-spacing: 0.02em; }
    .cta-button-outline:hover { background: rgba(255,255,255,0.12); border-color: #fff; color: #fff; text-decoration: none; }

    /* Bio with sidebar layout (homepage) */
    .bio-with-sidebar { display: grid; grid-template-columns: 1fr 200px; gap: 30px; padding: 10px 0 30px; }
    .bio-main { min-width: 0; }
    .bio-sidebar { display: flex; flex-direction: column; align-items: flex-start; gap: 20px; padding-top: 30px; }
    .bio-social-icons { display: flex; gap: 10px; }
    .bio-social-btn { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; color: #fff; text-decoration: none; transition: opacity 0.2s; }
    .bio-social-btn:hover { opacity: 0.85; text-decoration: none; }
    .bio-social-btn.fb { background: #1877f2; }
    .bio-social-btn.tw { background: #333; }
    .bio-social-btn.li { background: #0a66c2; }
    .cv-download-link { display: flex; align-items: center; gap: 10px; color: #333; text-decoration: none; font-size: 14px; font-weight: 500; }
    .cv-download-link:hover { color: var(--color-blue-accent); text-decoration: none; }
    .cv-icon { display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 8px; background: #f0fff4; }

    /* Expertise section with light blue background */
    .expertise-section { background: var(--color-bg-section); padding: 10px 0; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

    .content-with-sidebar { display: grid; grid-template-columns: 1fr 280px; gap: 40px; padding: 40px 0; }
    .content-main { min-width: 0; }
    .sidebar { border-left: 1px solid var(--color-border); padding-left: 30px; }
    .sidebar h3 { font-family: var(--font-heading); font-size: 18px; color: var(--color-heading); margin-bottom: 16px; line-height: 1.4; font-weight: 700; }
    .profile-links { list-style: none; }
    .profile-links li { margin-bottom: 12px; }
    .profile-links li a { display: flex; align-items: center; gap: 10px; color: var(--color-text); font-size: 14px; transition: color var(--transition-fast); text-decoration: none; }
    .profile-links li a:hover { color: var(--color-blue-accent); text-decoration: none; }
    .profile-icon { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; border-radius: 4px; }

    .bordered-section { border-left: 4px solid var(--color-gold); padding-left: 20px; margin: 30px 0; }

    /* Related resources silo navigation */
    .related-resources { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 2px solid var(--color-border); }
    .related-resources h2 { font-family: var(--font-heading); font-size: 1.15rem; color: var(--color-navy-light); margin-bottom: 1rem; font-weight: 700; }
    .resource-links { display: flex; flex-wrap: wrap; gap: 10px; }
    .resource-links a {
      display: inline-block; padding: 7px 16px; font-size: 0.9rem;
      background: var(--color-bg-light); color: var(--color-navy-light); border: 1px solid var(--color-border);
      border-radius: 4px; text-decoration: none; transition: all var(--transition-fast); font-weight: 500;
    }
    .resource-links a:hover { background: var(--color-navy-light); color: #fff; text-decoration: none; border-color: var(--color-navy-light); }

    /* Credential trust bar */
    .credential-bar {
      display: flex; flex-wrap: wrap; justify-content: center; gap: 20px;
      background: var(--color-bg-section); border: 1px solid var(--color-border);
      border-left: 4px solid var(--color-gold); border-radius: 4px;
      padding: 18px 24px; margin: 30px 0; text-align: center;
    }
    .credential-bar .cred-item {
      display: flex; align-items: center; gap: 8px;
      font-size: 0.92rem; color: var(--color-navy-light); font-weight: 600;
    }
    .credential-bar .cred-item .cred-num {
      font-size: 1.15rem; font-weight: 800; color: var(--color-gold-hover);
    }
    .credential-bar .cred-item a { color: var(--color-navy-light); text-decoration: none; }
    .credential-bar .cred-item a:hover { color: var(--color-gold-hover); text-decoration: underline; }
    .credential-bar .cred-companies {
      width: 100%; text-align: center; font-size: 0.82rem; color: var(--color-text-light);
      margin-top: 4px; font-weight: 400; line-height: 1.5;
    }
    @media (max-width: 600px) {
      .credential-bar { gap: 12px; padding: 14px 16px; }
      .credential-bar .cred-item { font-size: 0.85rem; }
    }

    /* CTA block */
    .cta-block {
      background: var(--color-navy); color: #fff; border-radius: 6px;
      padding: 30px 36px; margin: 35px 0; text-align: center;
    }
    .cta-block h3 { color: #fff; font-family: var(--font-heading); font-size: 1.25rem; margin: 0 0 10px 0; border: none; padding: 0; }
    .cta-block p { color: #cbd5e0; margin: 0 0 18px 0; font-size: 0.95rem; }
    .cta-block .cta-button {
      display: inline-block; background: var(--color-gold); color: var(--color-navy);
      padding: 12px 28px; border-radius: 4px; font-weight: 700; font-size: 0.95rem;
      text-decoration: none; transition: all var(--transition-fast);
    }
    .cta-block .cta-button:hover { background: var(--color-gold-hover); color: #fff; text-decoration: none; }

    /* Expertise page layouts (no sidebar, multi-column) */
    .content-full { padding: 40px 0; }
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 30px; }
    .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 30px; margin-bottom: 30px; }
    .two-col-text-img { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; margin-bottom: 30px; }
    .two-col-text-img img { width: 100%; height: auto; border-radius: 4px; }

    /* Expertise sub-page visual blocks */
    .content-full > h2 {
      border-left: 4px solid var(--color-gold);
      padding-left: 20px;
    }
    .content-full .three-col > div {
      border: 1px solid var(--color-border);
      border-left: 4px solid var(--color-gold);
      padding: 25px;
      background: #fff;
      border-radius: 4px;
      transition: box-shadow var(--transition-medium);
    }
    .content-full .three-col > div:hover { box-shadow: var(--shadow-card); }
    .content-full .three-col > div > h3 {
      font-size: 1.25rem;
    }
    .content-full .two-col > div {
      border: 1px solid var(--color-border);
      border-left: 4px solid var(--color-gold);
      padding: 25px;
      background: #fff;
      border-radius: 4px;
      transition: box-shadow var(--transition-medium);
    }
    .content-full .two-col > div:hover { box-shadow: var(--shadow-card); }
    .content-full .two-col > div > h3 {
      font-size: 1.25rem;
    }
    .content-full > h3 {
      border-left: 4px solid var(--color-gold);
      padding-left: 20px;
    }
    .content-full > ul {
      margin-bottom: 30px;
    }

    .client-logos { display: grid; grid-template-columns: repeat(6, 1fr); gap: 15px; padding: 20px 0; }
    .client-logo-item { display: flex; align-items: center; justify-content: center; padding: 12px; min-height: 70px; }
    .client-logo-item img { max-width: 130px; max-height: 50px; object-fit: contain; }
    .client-logos a, .client-logo-item a { text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
    .client-logos a:hover, .client-logo-item a:hover { text-decoration: none; opacity: 0.8; transition: opacity 0.2s; }
    .client-logos img { max-width: 130px; max-height: 50px; object-fit: contain; }
    /* Scale up Ericsson logo whose graphic is smaller within the SVG canvas */
