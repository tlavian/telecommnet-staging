  </div>

  <!-- Main Navigation -->
  <nav class="main-nav">
    <div class="container">
      <ul class="nav-links" id="navMenu">
        <li><a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a></li>
        <li><a href="/about-dr-lavian/" class={currentPath.includes('/about') ? 'active' : ''}>About</a></li>
        <li><a href="/communications-expert-witness/network-communications-expert-witness/" class={currentPath.includes('network-communications') ? 'active' : ''}>Expertise</a></li>
