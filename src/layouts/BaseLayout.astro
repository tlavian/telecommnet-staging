  </div>

  <!-- Main Navigation -->
  <nav class="main-nav" aria-label="Main navigation">
    <div class="container">
      <ul class="nav-links" id="navMenu" role="menubar">
        <li><a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a></li>
        <li><a href="/about-dr-lavian/" class={currentPath.includes('/about') ? 'active' : ''}>About</a></li>
        <li class="has-dropdown">
          <a href="/communications-expert-witness/" class={currentPath.includes('/communications-expert-witness') ? 'active' : ''}>Expertise <span class="dropdown-arrow">▾</span></a>
          <div class="dropdown dropdown-expertise">
            <a href="/communications-expert-witness/">All Expert Witness Services</a>
            <a href="/communications-expert-witness/pstn-voip-cellular-expert/">PSTN, VoIP &amp; Cellular</a>
            <a href="/communications-expert-witness/network-communications-expert-witness/">Network Communications</a>
