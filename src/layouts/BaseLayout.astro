---
interface Props {
  title: string;
  description?: string;
  schema?: object;
  ogImage?: string;
  ogType?: string;
  breadcrumbs?: Array<{name: string; url: string}>;
  robots?: string;
}

const { title, description = "Dr. Tal Lavian — Telecommunications Expert Witness. 70+ cases, 120+ patents. Network communications, VoIP, internet protocols. Ph.D. UC Berkeley.", schema, ogImage, ogType, breadcrumbs, robots = "index, follow" } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = `https://telecommnet.com${currentPath}`;
const defaultOgImage = "/images/og-default.jpg";
// OG images must be absolute URLs for social crawlers
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `https://telecommnet.com${ogImage}`)
  : `https://telecommnet.com${defaultOgImage}`;

// Human-readable names for URL slugs
const SLUG_LABELS: Record<string, string> = {
  'about-dr-lavian': 'About Dr. Lavian',
  'communications-expert-witness': 'Expert Witness Services',
  'pstn-voip-cellular-expert': 'PSTN, VoIP & Cellular Expert',
  'network-communications-expert-witness': 'Network Communications Expert',
  'internet-expert-witness': 'Internet Expert',
  'voice-over-ip-voip-expert': 'VoIP Expert',
  'network-security-expert': 'Network Security Expert',
  'streaming-media-audio-and-video-conferencing-expert': 'Streaming Media Expert',
  'computer-networking-expert-witness': 'Computer Networking Expert',
  'data-communications-expert': 'Data Communications Expert',
  'mobile-wireless-expert': 'Mobile & Wireless Expert',
  'routing-switching-expert': 'Routing & Switching Expert',
  'network-management-expert-witness': 'Network Management Expert',
  'networking-expert': 'Networking Expert',
  'messaging-and-chat-expert-witness': 'Messaging & Chat Expert',
  'corporate-clients': 'Corporate Clients',
  'law-firm-clients': 'Law Firm Clients',
  'scientific-publications': 'Scientific Publications',
  'talks-presentations': 'Talks & Presentations',
  'cases-expert-witness-testimony': 'Expert Witness Cases',
  'site-map': 'Site Map',
  'contact': 'Contact',
  'privacy-policy': 'Privacy Policy',
  'terms-and-conditions': 'Terms & Conditions',
  'patents': 'Patents',
  'publication': 'Publications',
  'case': 'Cases',
  'category': 'Category',
};

// Convert slug to readable label: check map first, then humanize
function slugToLabel(slug: string): string {
  if (SLUG_LABELS[slug]) return SLUG_LABELS[slug];
  // Capitalize words, replace hyphens with spaces
  return slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}

// Auto-generate breadcrumbs from URL path if not explicitly provided
function autoBreadcrumbs(path: string): Array<{name: string; url: string}> {
  if (path === '/') return []; // Homepage doesn't need breadcrumbs
  const segments = path.replace(/^\/|\/$/g, '').split('/');
  const crumbs: Array<{name: string; url: string}> = [
    { name: 'Home', url: '/' }
  ];
  let builtPath = '';
  for (const seg of segments) {
    builtPath += '/' + seg;
    crumbs.push({ name: slugToLabel(seg), url: builtPath + '/' });
  }
  return crumbs;
}

// Check if page schema already contains a BreadcrumbList
function schemaHasBreadcrumbs(s: any): boolean {
  if (!s) return false;
  if (s['@type'] === 'BreadcrumbList') return true;
  if (s['@graph']) return s['@graph'].some((node: any) => node?.['@type'] === 'BreadcrumbList');
  return false;
}

// Only auto-generate breadcrumbs if page schema doesn't already include them
const needsAutoBreadcrumbs = !schemaHasBreadcrumbs(schema) && !breadcrumbs;
const resolvedBreadcrumbs = breadcrumbs || (needsAutoBreadcrumbs ? autoBreadcrumbs(currentPath) : []);

// Generate BreadcrumbList schema from breadcrumbs
const breadcrumbSchema = resolvedBreadcrumbs.length > 0 ? {
  "@type": "BreadcrumbList",
  "itemListElement": resolvedBreadcrumbs.map((crumb, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": crumb.name,
    "item": `https://telecommnet.com${crumb.url}`
  }))
} : null;

// Merge breadcrumb schema into existing schema @graph, or create standalone
function buildFullSchema(pageSchema: any, bcSchema: any) {
  if (!pageSchema && !bcSchema) return null;
  if (!pageSchema && bcSchema) return { "@context": "https://schema.org", ...bcSchema };
  if (pageSchema && !bcSchema) return pageSchema;
  // If page schema has @graph, add breadcrumb to it
  if (pageSchema["@graph"]) {
    return { ...pageSchema, "@graph": [...pageSchema["@graph"], bcSchema] };
  }
  // Otherwise create @graph with both
  return {
    "@context": "https://schema.org",
    "@graph": [pageSchema["@type"] ? pageSchema : undefined, bcSchema].filter(Boolean)
  };
}

const fullSchema = buildFullSchema(schema, breadcrumbSchema);
