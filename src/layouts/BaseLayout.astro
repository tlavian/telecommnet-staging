  <!-- DNS prefetch for deferred external resources -->
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
  <!-- Self-hosted fonts: eliminates 2 external network requests (fonts.googleapis.com + fonts.gstatic.com) -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/inter-400.woff2" crossorigin />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/merriweather-700.woff2" crossorigin />
  {currentPath === '/' && <link rel="preload" as="image" type="image/webp" href="/images/heroes/header-banner.webp" fetchpriority="high" />}
  {fullSchema && <script type="application/ld+json" set:html={JSON.stringify(fullSchema)} />}
  <!-- Google Analytics (deferred for performance — loads after browser idle) -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    (function(){
      function loadGA(){
        var s=document.createElement('script');
        s.src='https://www.googletagmanager.com/gtag/js?id=G-GCHFJ79Q1P';
        s.async=true;
        document.head.appendChild(s);
        gtag('js',new Date());
        gtag('config','G-GCHFJ79Q1P');
      }
      if('requestIdleCallback' in window){requestIdleCallback(loadGA);}
      else{setTimeout(loadGA,2000);}
    })();
  </script>
  <!-- GA4 Event Tracking (deferred to idle for performance) -->
  <script is:inline>
    function setupGATracking(){
      document.querySelectorAll('a[href^="tel:"]').forEach(function(l){l.addEventListener('click',function(){gtag('event','phone_click',{event_category:'engagement',event_label:l.getAttribute('href')})})});
      document.querySelectorAll('a[href^="mailto:"]').forEach(function(l){l.addEventListener('click',function(){gtag('event','email_click',{event_category:'engagement',event_label:l.getAttribute('href')})})});
      document.querySelectorAll('.cta-button,.hero-cta').forEach(function(b){b.addEventListener('click',function(){gtag('event','cta_click',{event_category:'engagement',event_label:b.textContent.trim()})})});
      var f=document.querySelector('form');if(f){f.addEventListener('submit',function(){gtag('event','contact_form_submit',{event_category:'conversion',event_label:window.location.pathname})})}
      document.querySelectorAll('a[href$=".pdf"]').forEach(function(l){l.addEventListener('click',function(){gtag('event','file_download',{event_category:'engagement',event_label:l.getAttribute('href')})})});
    }
    if('requestIdleCallback' in window){requestIdleCallback(setupGATracking);}
    else{document.addEventListener('DOMContentLoaded',setupGATracking);}
  </script>
  <style is:global>
